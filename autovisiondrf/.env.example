# Local Development Settings
SECRET_KEY=local-django-insecure-key-change-me
DEBUG=True

# In production (Render), these should be set in their environment variables dashboard
# ALLOWED_HOSTS=your-app.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-react-UI-domain.com

# For local development with SQLite, leave DATABASE_URL blank or comment it out
